# ---------------------------------------------------------------------------
# Inventory Management — example environment file.
# Copy to `.env` and adjust for your machine. `.env` is gitignored.
# ---------------------------------------------------------------------------

# Host/port the Flask server binds to.
INVENTORY_HOST=127.0.0.1
INVENTORY_PORT=5000

# Path to the SQLite file. Relative paths are resolved against the project root
# (the directory that contains main.py). The file is created on first run.
INVENTORY_DB_PATH=inventory.db

# Flask session signing key. MUST be a long random string in any non-dev env.
# Changing this value invalidates all existing session cookies.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
INVENTORY_SECRET_KEY=change-me-to-a-long-random-string

# Seed admin credentials. Applied only on first run if the user does not exist.
# Registration is not implemented yet, so this is currently the only way to
# create a user. Change these before deploying anywhere real.
INVENTORY_ADMIN_USERNAME=admin
INVENTORY_ADMIN_PASSWORD=change-me-admin-password

# Allowed CORS origin for /api/* (exact match, with credentials). The Vite dev
# server runs on 5173 by default. Use "*" only for quick local experiments —
# credentials will not be sent when the origin is a wildcard.
INVENTORY_CORS_ORIGIN=http://127.0.0.1:5173

# Python logging level. One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
INVENTORY_LOG_LEVEL=INFO

# Set to 1 when serving over HTTPS so the session cookie is marked Secure.
# Keep 0 for plain-http local development.
INVENTORY_SESSION_SECURE=0
